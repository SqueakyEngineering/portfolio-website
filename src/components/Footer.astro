    <p>&copy; {year} [PLACEHOLDER: Miles Scheetz]. Built with Astro, Tailwind CSS, GitHub, and Vercel.</p>
    <div class="flex gap-4">
      <a class="hover:text-white" href="https://github.com/placeholder-username">GitHub</a>
      <a class="hover:text-white" href="https://www.linkedin.com/in/placeholder-profile/">LinkedIn</a>
      <a class="hover:text-white" href="mailto:placeholder.email@example.com">Email</a>
    </div>
  </div>
</footer>
