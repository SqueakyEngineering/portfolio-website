---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/resume/', label: 'Resume' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-zinc-950/85 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Primary navigation">
    <a href="/" class="font-mono text-sm font-semibold tracking-wide text-zinc-100">
      Miles Scheetz
    </a>
    <div class="flex flex-wrap items-center justify-end gap-1 sm:gap-2">
      {
        navItems.map((item) => {
          const active = item.href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                'rounded px-3 py-2 text-sm transition',
                active ? 'bg-white text-zinc-950' : 'text-zinc-300 hover:bg-white/10 hover:text-white',
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>
