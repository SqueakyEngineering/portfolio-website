---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getFeaturedProjects } from '../lib/projects';

const projects = await getFeaturedProjects();
---

<Layout
  title="Miles Scheetz"
  description="Mechanical Engineering student with co-op and manufacturing experience in prototyping, design for manufacturability, and process optimization."
>
  <section class="relative min-h-[78svh] overflow-hidden border-b border-white/10">
    <img
      class="absolute inset-0 h-full w-full object-cover opacity-50"
      src="/images/engineering-hero.png"
      alt="Engineering workspace with laptop, electronics, and aerospace notes"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(9,9,11,0.96)_0%,rgba(9,9,11,0.78)_44%,rgba(9,9,11,0.28)_100%)]"></div>
    <div class="relative mx-auto flex min-h-[78svh] max-w-6xl items-center px-4 py-14 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="font-mono text-sm uppercase tracking-[0.24em] text-teal-200">MECHANICAL ENGINEERING STUDENT</p>
        <h1 class="mt-6 max-w-4xl text-4xl font-semibold leading-tight text-white sm:text-6xl sm:leading-none lg:text-7xl">
          Miles Scheetz
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-200">
          I'm a Mechanical Engineering student with 1.5 years as an engineering co-op and 4+ years of experience in manufacturing. Skilled in prototyping, design-for-manufacturability, and process optimization, with experience working across both production and engineering environments.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="rounded bg-teal-300 px-5 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-teal-200" href="/projects/">View projects</a>
          <a class="rounded border border-white/20 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10" href="/resume/">Resume</a>
          <a class="rounded border border-white/20 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10" href="/contact/">Contact</a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-zinc-900/40">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="font-mono text-sm uppercase tracking-[0.2em] text-teal-200">Featured projects</p>
          <h2 class="mt-4 text-3xl font-semibold text-white">Engineering Projects</h2>
        </div>
        <a class="text-sm font-medium text-teal-200 hover:text-teal-100" href="/projects/">All projects -&gt;</a>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-5 px-4 py-20 sm:px-6 md:grid-cols-2 lg:px-8">
    <div class="rounded-lg border border-white/10 bg-zinc-900/70 p-6">
      <p class="font-mono text-sm uppercase tracking-[0.2em] text-amber-300">RESUME</p>
      <h2 class="mt-4 text-2xl font-semibold text-white">Check Out My Resume!</h2>
      <p class="mt-3 text-sm leading-6 text-zinc-300">Have I mentioned my resume enough?</p>
      <a class="mt-6 inline-flex rounded bg-white px-4 py-2 text-sm font-semibold text-zinc-950 hover:bg-zinc-200" href="/resume/">Open resume</a>
    </div>
    <div class="rounded-lg border border-white/10 bg-zinc-900/70 p-6">
      <p class="font-mono text-sm uppercase tracking-[0.2em] text-teal-200" data-dev-edit-key="home-contact-card:eyebrow">CONTACT</p>
      <h2 class="mt-4 text-2xl font-semibold text-white" data-dev-edit-key="home-contact-card:title">Let's Connect!</h2>
      <p class="mt-3 text-sm leading-6 text-zinc-300" data-dev-edit-key="home-contact-card:body">I'm always happy to hear about job opportunities, collaboration ideas, and sci-fi book recommendations.</p>
      <a class="mt-6 inline-flex rounded bg-teal-300 px-4 py-2 text-sm font-semibold text-zinc-950 hover:bg-teal-200" href="/contact/" data-dev-edit-key="home-contact-card:cta">Connect</a>
    </div>
  </section>
</Layout>
