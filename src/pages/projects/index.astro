---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getSortedProjects } from '../../lib/projects';

const projects = await getSortedProjects();
---

<Layout
  title="Projects"
  description="A collection of mechanical engineering projects, rocket builds, and technical experiments by Miles Scheetz."
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="font-mono text-sm uppercase tracking-[0.2em] text-teal-200">Projects</p>
    <h1 class="mt-4 max-w-3xl text-4xl font-semibold text-white sm:text-5xl">Engineering Projects</h1>
    <p class="mt-5 max-w-2xl text-base leading-8 text-zinc-300">
      This is the fun part
    </p>
    <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</Layout>
