---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Resume"
  description="Resume for Miles Scheetz."
>
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 pb-6 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="font-mono text-sm uppercase tracking-[0.2em] text-teal-200">Resume</p>
        <h1 class="mt-3 text-4xl font-semibold text-white sm:text-5xl">Miles Scheetz</h1>
      </div>
      <a class="inline-flex rounded bg-white px-5 py-3 text-sm font-semibold text-zinc-950 hover:bg-zinc-200" href="/resume.pdf" download="Resume-Miles Scheetz.pdf">Download PDF</a>
    </div>

    <div class="mx-auto max-w-[900px]">
      <iframe
        class="block aspect-[8.5/11] h-auto w-full overflow-hidden bg-transparent"
        src="/resume.pdf#view=FitH&zoom=page-width&pagemode=none&toolbar=0&navpanes=0"
        title="Miles Scheetz resume PDF"
        scrolling="no"
      ></iframe>
    </div>
  </section>
</Layout>
