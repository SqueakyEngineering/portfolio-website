---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Contact Miles Scheetz for engineering opportunities, collaborations, or technical conversations."
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="font-mono text-sm uppercase tracking-[0.2em] text-teal-200">Contact</p>
    <h1 class="mt-4 text-4xl font-semibold text-white sm:text-5xl">Let's build something useful.</h1>
    <p class="mt-5 max-w-2xl text-base leading-8 text-zinc-300">
      If you'd like to connect for any reason, send me an email at miles1scheetz@gmail.com.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      <a class="rounded-lg border border-white/10 bg-zinc-900/70 p-5 transition hover:border-teal-300/60 hover:bg-zinc-900" href="mailto:miles1scheetz@gmail.com">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">Email</p>
        <p class="mt-3 text-white">miles1scheetz@gmail.com</p>
      </a>
      <a class="rounded-lg border border-white/10 bg-zinc-900/70 p-5 transition hover:border-teal-300/60 hover:bg-zinc-900" href="https://github.com/SqueakyEngineering">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">GitHub</p>
        <p class="mt-3 text-white">github.com/SqueakyEngineering</p>
      </a>
      <a class="rounded-lg border border-white/10 bg-zinc-900/70 p-5 transition hover:border-teal-300/60 hover:bg-zinc-900" href="https://www.linkedin.com/in/miles-scheetz/">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">LinkedIn</p>
        <p class="mt-3 text-white">linkedin.com/in/miles-scheetz</p>
      </a>
      <a class="rounded-lg border border-white/10 bg-zinc-900/70 p-5 transition hover:border-teal-300/60 hover:bg-zinc-900" href="https://www.goodreads.com/user/show/64908740-miles-scheetz">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">GOODREADS</p>
        <p class="mt-3 text-white">https://www.goodreads.com/user/show/64908740-miles-scheetz</p>
      </a>
    </div>
  </section>
</Layout>
