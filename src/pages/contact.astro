---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="[PLACEHOLDER: Contact page for engineering roles, collaborations, and technical conversations.]"
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="font-mono text-sm uppercase tracking-[0.2em] text-teal-200">Contact</p>
    <h1 class="mt-4 text-4xl font-semibold text-white sm:text-5xl">[PLACEHOLDER: Let us build something useful.]</h1>
    <p class="mt-5 max-w-2xl text-base leading-8 text-zinc-300">
      [PLACEHOLDER: Replace this with the best way to reach you and the kinds of roles, projects, or collaborations you are open to discussing.]
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      <a class="rounded-lg border border-white/10 bg-zinc-900/70 p-5 transition hover:border-teal-300/60 hover:bg-zinc-900" href="mailto:placeholder.email@example.com">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">Email</p>
        <p class="mt-3 text-white">placeholder.email@example.com</p>
      </a>
      <a class="rounded-lg border border-white/10 bg-zinc-900/70 p-5 transition hover:border-teal-300/60 hover:bg-zinc-900" href="https://github.com/placeholder-username">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">GitHub</p>
        <p class="mt-3 text-white">github.com/placeholder-username</p>
      </a>
      <a class="rounded-lg border border-white/10 bg-zinc-900/70 p-5 transition hover:border-teal-300/60 hover:bg-zinc-900" href="https://www.linkedin.com/in/placeholder-profile/">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">LinkedIn</p>
        <p class="mt-3 text-white">linkedin.com/in/placeholder-profile</p>
      </a>
      <div class="rounded-lg border border-white/10 bg-zinc-900/70 p-5">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">Location</p>
        <p class="mt-3 text-white">[PLACEHOLDER: City, State or Remote]</p>
      </div>
    </div>
  </section>
</Layout>
